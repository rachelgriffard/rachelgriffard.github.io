---
// DNALogo.astro — mouse-driven double-helix nav brand
---

<a href="/" class="nav-brand dna-logo-link">
  <svg
    class="dna-icon"
    viewBox="0 0 20 32"
    width="26"
    height="40"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <defs>
      <clipPath id="dna-clip">
        <rect x="0" y="0" width="20" height="32" />
      </clipPath>
    </defs>
    <g clip-path="url(#dna-clip)">
      <path class="dna-s1" stroke="#31081f" stroke-width="2.2" stroke-linecap="round" fill="none"/>
      <path class="dna-s2" stroke="#6b0f1a" stroke-width="2.2" stroke-linecap="round" fill="none" opacity="0.8"/>
      <line class="dna-bp" stroke="#a8b5ad" stroke-width="1.4" stroke-linecap="round"/>
      <line class="dna-bp" stroke="#a8b5ad" stroke-width="1.4" stroke-linecap="round"/>
      <line class="dna-bp" stroke="#a8b5ad" stroke-width="1.4" stroke-linecap="round"/>
      <line class="dna-bp" stroke="#a8b5ad" stroke-width="1.4" stroke-linecap="round"/>
    </g>
  </svg>
  <span>Rachel Griffard-Smith</span>
</a>

<style>
  .dna-logo-link {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
</style>

<script>
  // Helix geometry (SVG units)
  const PERIOD = 24;  // px per full rotation
  const CX     = 10;  // horizontal centre
  const AMP    =  8;  // strand swings from x=2 to x=18
  const H      = 32;  // visible SVG height
  const N      = 60;  // path segments (smooth curve)

  const svg    = document.querySelector('.dna-icon')!;
  const s1     = svg.querySelector('.dna-s1')  as SVGPathElement;
  const s2     = svg.querySelector('.dna-s2')  as SVGPathElement;
  const bps    = svg.querySelectorAll('.dna-bp') as NodeListOf<SVGLineElement>;

  function draw(phase: number) {
    // --- strands ---
    let d1 = '', d2 = '';
    for (let i = 0; i <= N; i++) {
      const y = (i / N) * H;
      const a = 2 * Math.PI * y / PERIOD + phase;
      // strand 1 starts left (x=2) at y=0, phase=0
      const x1 = CX - AMP * Math.cos(a);
      const x2 = CX + AMP * Math.cos(a);
      const cmd = i === 0 ? 'M' : 'L';
      d1 += `${cmd}${x1.toFixed(2)},${y.toFixed(2)} `;
      d2 += `${cmd}${x2.toFixed(2)},${y.toFixed(2)} `;
    }
    s1.setAttribute('d', d1.trim());
    s2.setAttribute('d', d2.trim());

    // --- base-pair rungs ---
    // Rungs sit every half-period; their y position shifts with phase.
    // phaseShift converts phase angle → y offset so rungs track the strands.
    const halfP     = PERIOD / 2;                       // 12 px between rungs
    const phaseShift = (phase / (2 * Math.PI)) * PERIOD; // how far rungs shift in y

    let used = 0;
    for (let n = -1; n <= 5 && used < bps.length; n++) {
      const y = n * halfP - phaseShift;
      if (y < -0.5 || y > H + 0.5) continue;

      // At a rung position, cos(a) = ±1, so x1=2,x2=18 or x1=18,x2=2
      const a  = 2 * Math.PI * y / PERIOD + phase;
      const x1 = (CX - AMP * Math.cos(a)).toFixed(2);
      const x2 = (CX + AMP * Math.cos(a)).toFixed(2);

      bps[used].setAttribute('x1', x1);
      bps[used].setAttribute('x2', x2);
      bps[used].setAttribute('y1', y.toFixed(2));
      bps[used].setAttribute('y2', y.toFixed(2));
      bps[used].removeAttribute('visibility');
      used++;
    }
    for (let i = used; i < bps.length; i++) {
      bps[i].setAttribute('visibility', 'hidden');
    }
  }

  // Initial render (no mouse yet)
  draw(0);

  document.addEventListener('mousemove', (e) => {
    // Map mouse X across page → one full rotation (0 → 2π)
    draw((e.clientX / window.innerWidth) * 2 * Math.PI);
  });
</script>
