---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About | Rachel Griffard-Smith"
  description="About Rachel Griffard-Smith — data scientist, artist, and lover of dogs and the outdoors."
>
  <div class="container">

    <!-- Bio -->
    <section class="about-hero">
      <img
        src="https://github.com/rachelgriffard/digital-cv/assets/95938614/787b7baf-c4f6-48bc-9b11-18b10ea2bbe5"
        alt="Rachel Griffard-Smith"
        class="about-avatar"
      />
      <h1 class="about-name">Rachel Griffard-Smith</h1>
      <p class="about-role">Bioinformatic Data Scientist &middot; University of Kansas Medical Center</p>

      <div class="about-bio-text">
        <p>
          I'm a data scientist, artist, and nature lover. When I'm not decoding
          complex biology from large, heterogenous datasets with code and stats, I'm capturing moments through photography,
          crafting collages, or bouldering. 
        </p>
        <p>
          I work at the University of Kansas Medical Center, where I prioritize reproducible science
          by building pipelines and packages for a huge variety of data types and analyses
          and contribute to published research through consulting across a variety of domain expertise.
        </p>
        <p>
          I am most passionate about the democratization of data. I am committed to ensuring that knowledge from data 
          is not lost in poor visualizations, inaccessible code, or choppy writing; I strive to 
          take complex findings in biological data and making them accessible to not only a broad audience
          of data experts, but also to those without domain experience. I find true passion in being able to explain complex
          insights from data in a way that is clear, engaging, and actionable for a wide variety of audiences.
        </p>
      </div>
    </section>

    <!-- Photos -->
    <section class="about-gallery-section">
      <h2 class="about-gallery-title">Life Outside the Office</h2>
      <div class="about-gallery-divider"></div>

      <div class="about-photo-group">
        <h3 class="about-photo-label">My Dogs</h3>
        <div class="photo-grid">
          <img src="/images/penny.jpg" alt="Penny Lane" />
          <img src="/images/duchess.jpg" alt="Duchess" />
          <img src="/images/hobbes.jpg" alt="Hobbes" />
        </div>
      </div>

      <div class="about-photo-row">
        <div class="about-photo-group">
          <h3 class="about-photo-label">The family</h3>
          <img src="/images/rachel-and-jack.JPG" alt="Rachel and Jack" class="about-photo-single" />
        </div>
        <div class="about-photo-group">
          <h3 class="about-photo-label">Bouldering</h3>
          <img src="/images/climbing.gif.gif" alt="Rachel rock climbing" class="about-photo-single" />
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
