---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="CV | Rachel Griffard-Smith"
  description="Curriculum vitae for Rachel Griffard-Smith, Bioinformatician at the University of Kansas Medical Center."
>
  <div class="container">
    <div class="cv-layout">
      <!-- Sidebar -->
      <aside class="cv-sidebar">
        <img
          src="https://github.com/rachelgriffard/digital-cv/assets/95938614/787b7baf-c4f6-48bc-9b11-18b10ea2bbe5"
          alt="Rachel Griffard-Smith"
          class="avatar"
        />
        <h2>Rachel Griffard-Smith</h2>
        <p class="cv-role">Bioinformatician</p>

        <div class="cv-sidebar-section">
          <h3>Contact</h3>
          <a href="mailto:rachelgriffard@gmail.com">
            &#9993; rachelgriffard@gmail.com
          </a>
          <a
            href="https://www.linkedin.com/in/rachelgriffard"
            target="_blank"
            rel="noopener noreferrer"
          >
            in LinkedIn
          </a>
          <a
            href="https://orcid.org/0000-0002-3330-695X"
            target="_blank"
            rel="noopener noreferrer"
          >
            ORCID 0000-0002-3330-695X
          </a>
          <a
            href="https://github.com/rachelgriffard"
            target="_blank"
            rel="noopener noreferrer"
          >
            &#9675; GitHub
          </a>
        </div>

        <div class="cv-sidebar-section">
          <h3>Skills</h3>
          <div class="skill-tags">
            <span class="skill-tag">R</span>
            <span class="skill-tag">Python</span>
            <span class="skill-tag">SQL</span>
            <span class="skill-tag">Unix</span>
            <span class="skill-tag">Markdown</span>
            <span class="skill-tag">scRNA-seq</span>
            <span class="skill-tag">Bulk RNA-seq</span>
            <span class="skill-tag">Bioinformatics</span>
            <span class="skill-tag">Statistics</span>
          </div>
        </div>
      </aside>

      <!-- Main content -->
      <div class="cv-main">
        <section class="cv-section">
          <h2 class="cv-section-title">Experience</h2>

          <div class="cv-entry">
            <h3>Bioinformatician I</h3>
            <p class="cv-meta">
              University of Kansas Medical Center &mdash; June 2024 to Present
            </p>
            <ul>
              <li>Build and maintain pipelines for preprocessing and analysis of 'omic data</li>
              <li>Collaborate across research teams on bioinformatics projects</li>
            </ul>
          </div>

          <div class="cv-entry">
            <h3>Graduate Research Assistant</h3>
            <p class="cv-meta">
              University of Kansas Medical Center &mdash; August 2022 to May 2024
            </p>
            <ul>
              <li>Processed and analyzed bulk and single-cell RNA-sequencing data</li>
              <li>Contributed to publications in peer-reviewed journals</li>
              <li>Developed the micRoclean R package for microbiome decontamination</li>
            </ul>
          </div>
        </section>

        <section class="cv-section">
          <h2 class="cv-section-title">Education</h2>

          <table class="cv-table">
            <thead>
              <tr>
                <th>School</th>
                <th>Degree</th>
                <th>Years</th>
                <th>GPA</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>University of Kansas Medical Center</td>
                <td>M.S. Health Data Science</td>
                <td>2022&ndash;2024</td>
                <td>4.0</td>
              </tr>
              <tr>
                <td>University of Kansas</td>
                <td>B.S. Behavioral Neuroscience</td>
                <td>2017&ndash;2020</td>
                <td>3.9</td>
              </tr>
            </tbody>
          </table>
        </section>

        <section class="cv-section">
          <h2 class="cv-section-title">Publications &amp; Projects</h2>

          <div class="pub-list">
            <div class="pub-card">
              <span class="pub-status submitted">Submitted</span>
              <h3>
                Therapeutic Potential of NRF2 activating drug RTA-408 in
                suppressing T-cell effector responses and inflammatory bowel
                disease
              </h3>
              <p class="pub-authors">
                Griffard-Smith, R., Dasgupta, D., Tripathi, A., Yellapu, N.K.,
                Pyaram, K.
              </p>
              <p class="pub-journal">Cell Reports</p>
            </div>

            <div class="pub-card">
              <span class="pub-status in-prep">In Progress</span>
              <h3>
                Fixed single-cell RNA sequencing analysis of mouse models of
                asthma
              </h3>
              <p class="pub-authors">
                Griffard-Smith, R., Sundar, I., Prasad, C.
              </p>
            </div>

            <div class="pub-card">
              <span class="pub-status published">Published</span>
              <h3>
                micRoclean: an R package for decontaminating low biomass
                16S-rRNA microbiome data
              </h3>
              <p class="pub-authors">
                Griffard-Smith, R., Pei, D., Schueddig, E., Mahoney, D.,
                Chalise, P., Koestler, D.
              </p>
              <p class="pub-journal">Frontiers in Bioinformatics, 2025</p>
              <div class="pub-links">
                <a
                  href="https://www.frontiersin.org/journals/bioinformatics/articles/10.3389/fbinf.2025.1556361/full"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="pub-link"
                >Paper</a>
                <a
                  href="https://github.com/rachelgriffard/micRoclean"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="pub-link"
                >GitHub</a>
              </div>
            </div>
          </div>
        </section>

        <section class="cv-section">
          <h2 class="cv-section-title">Professional Training</h2>

          <div class="cv-entry">
            <h3>Single Cell RNA-seq Workshop</h3>
            <p class="cv-meta">
              National Center for Genome Resources / New Mexico-INBRE &mdash; November 2023
            </p>
            <ul>
              <li>
                Hands-on work with SingleCellExperiment and Seurat within a
                UNIX environment
              </li>
              <li>
                Applied and expanded Unix and R knowledge for scRNA-seq
                processing and analysis
              </li>
            </ul>
          </div>

          <div class="cv-entry">
            <h3>Epic Cosmos Data Model Certification</h3>
            <p class="cv-meta">Epic &mdash; June 2023</p>
            <ul>
              <li>
                Certified for the
                <a
                  href="https://cosmos.epic.com/"
                  target="_blank"
                  rel="noopener noreferrer"
                >Cosmos deidentified dataset</a>
              </li>
            </ul>
          </div>

          <div class="cv-entry">
            <h3>IBM Data Science Professional Certificate</h3>
            <p class="cv-meta">Coursera &mdash; 2022</p>
          </div>

          <div class="cv-entry">
            <h3>SQL for Data Science with R</h3>
            <p class="cv-meta">edX &mdash; 2021&ndash;2022</p>
          </div>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>
