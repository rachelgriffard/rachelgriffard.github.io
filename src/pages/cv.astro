              <span class="cv-edu-meta">University of Kansas Medical Center &middot; 2022&ndash;2024 &middot; 4.0 GPA</span>
            </div>
            <p class="coursework-label">Relevant coursework</p>
            <div class="skill-tags">
              <span class="skill-tag">Linear Regression</span>
              <span class="skill-tag">Categorical Data Analysis</span>
              <span class="skill-tag">Introduction to Bioinformatics</span>
              <span class="skill-tag">Survival Analysis</span>
              <span class="skill-tag">Observational Health Data Analysis</span>
              <span class="skill-tag">Statistical Methods in Genomic Research</span>
              <span class="skill-tag">Data Visualization &amp; Acquisition</span>
              <span class="skill-tag">Statistical Learning I &amp; II</span>
              <span class="skill-tag">Clinical Trials</span>
              <span class="skill-tag">Data Mining &amp; Analytics</span>
