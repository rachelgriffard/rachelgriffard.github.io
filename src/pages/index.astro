---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Rachel Griffard-Smith">
  <div class="container">
    <section class="hero">
      <h1>Rachel Griffard-Smith</h1>
      <p class="bio-short">
        Bioinformatic Data Scientist at the University of Kansas Medical Center passionate about the democratization of data. Lover of
        collage, photography, and climbing big (usually plastic) rocks.
      </p>
      <div class="hero-links">
        <a href="/cv" class="btn btn-primary">View CV</a>
        <a href="/about" class="btn btn-outline">About Me</a>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Highlights</h2>
        <div class="section-line"></div>
      </div>
      <div class="highlights-grid">
        <div class="highlight-card">
          <h3>Data Science</h3>
          <p>Data scientist at KUMC, consulting across six concurrent research teams to scope analytical approaches, build end-to-end pipelines, and deliver clear insights from large, complex datasets.</p>
        </div>
        <div class="highlight-card">
          <h3>Methods</h3>
          <p>Experienced in statistical modeling, supervised & unsupervised machine learning, causal inference, and dimensionality reduction — applied across high-dimensional, heterogeneous data on HPC infrastructure.</p>
        </div>
        <div class="highlight-card">
          <h3>Open Source</h3>
          <p>Developer of two open-source R packages adopted by external research teams, and a <a href="https://www.nextflow.io/our_ambassadors.html">Nextflow Ambassador</a> contributing to a globally distributed pipeline development community.</p>
        </div>
      </div>
    </section>
    </div>
    </BaseLayout>

<style>
  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .highlight-card {
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .highlight-card h3 {
    margin: 0 0 0.5rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
  }

  .highlight-card p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>
