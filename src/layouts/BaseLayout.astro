---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Rachel Griffard-Smith — Bioinformatician, artist, and nature lover.",
} = Astro.props;

const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Rachel Griffard-Smith" />
    <title>{title}</title>
    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <nav class="site-nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">Rachel Griffard-Smith</a>
        <ul class="nav-links">
          <li>
            <a href="/" class:list={[{ active: pathname === "/" }]}>Home</a>
          </li>
          <li>
            <a
              href="/posts"
              class:list={[{ active: pathname.startsWith("/posts") }]}
            >Posts</a>
          </li>
          <li>
            <a
              href="/about"
              class:list={[{ active: pathname === "/about" }]}
            >About</a>
          </li>
          <li>
            <a href="/cv" class:list={[{ active: pathname === "/cv" }]}>CV</a>
          </li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <span class="footer-brand">Rachel Griffard-Smith</span>
        <ul class="footer-nav">
          <li><a href="/">Home</a></li>
          <li><a href="/posts">Posts</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/cv">CV</a></li>
        </ul>
        <p class="footer-copy">
          &copy; 2025 Rachel Griffard-Smith &middot;
          <a href="https://github.com/rachelgriffard" target="_blank">GitHub</a>
        </p>
      </div>
    </footer>
  </body>
</html>
